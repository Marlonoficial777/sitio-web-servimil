  .cn-d1 { animation-delay: 0.1s; }
  .cn-d2 { animation-delay: 0.25s; }
  .cn-d3 { animation-delay: 0.42s; }
  .cn-d4 { animation-delay: 0.7s; }

  /* Bounce sutil del indicador de scroll */
  @keyframes cnBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  .cn-bounce {
    animation: cnBounce 1.8s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .cn-in {
      opacity: 1;
      animation: none;
    }
    .cn-bounce {
      animation: none;
    }
  }

  /* === BORDE NARANJA HOVER/ACTIVE — cards "Nuestros valores" (reversible) ===
     Al pasar el mouse / hacer click: contorno naranja en los 4 lados
     (border-color) + leve glow. Conserva la elevación y la rayita superior
     (esa es un <span> aparte, no se toca). Ajustar aquí color/intensidad. */
  .val-card {

    border-color: #F34616;
    box-shadow:
      0 34px 64px rgba(1, 17, 38, 0.16),   /* elevación (igual que antes) */
      0 0 0 1px rgba(243, 70, 22, 0.55),   /* refuerza el contorno naranja */

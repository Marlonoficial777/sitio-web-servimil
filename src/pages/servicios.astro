  <script is:inline>
    (() => {
      const PLAN_IDS = ["plan-plus", "plan-plus-superior", "plan-elite"];
      const flash = () => {
        const id = (location.hash || "").replace("#", "");
        if (!PLAN_IDS.includes(id)) return;
        const el = document.getElementById(id);
        if (!el) return;
        el.classList.remove("plan-highlight");
        void el.offsetWidth; // reinicia la animación
        el.classList.add("plan-highlight");
        el.addEventListener(
          "animationend",
          () => el.classList.remove("plan-highlight"),
          { once: true },
        );
      };
      // pequeño delay para dar tiempo al scroll del ancla
      window.addEventListener("load", () => setTimeout(flash, 400));
      window.addEventListener("hashchange", flash);
    })();
  </script>

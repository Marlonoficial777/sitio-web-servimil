---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Servimil — Beneficios para las Fuerzas Armadas y sus familias",
  description = "Servimil respalda a los integrantes del Ministerio de Defensa y las Fuerzas Armadas: salud, asistencia jurídica, seguros, crédito y más. Disponibilidad 24/7/365.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>

    <!-- Tipografía de marca: Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </head>
  <body>
    <slot />

    <!-- Reveal al hacer scroll (motion sutil, accesible) -->
    <script>
      const reveal = () => {
        const els = document.querySelectorAll("[data-reveal]");
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach((el) => io.observe(el));
      };
      reveal();
    </script>
  </body>
</html>

---
import Icon from "./Icon.astro";

const GRUPOS = [
  { icon: "money", title: "Financiero", desc: "Soluciones de dinero, nómina y renta." },
  { icon: "heart", title: "Salud y Bienestar", desc: "Médico en casa, telemedicina y más." },
  { icon: "shield", title: "Familia y Protección", desc: "Bono de condolencia, seguros, educación." },
  { icon: "sparkle", title: "Nuevos Servicios", desc: "Mascota, tecnología, viajes y jurídica." },
];
---
<section class="bg-ice">
  <div class="mx-auto max-w-[1200px] px-6 py-[88px]">
    <div data-reveal class="mx-auto mb-11 max-w-[680px] text-center">
      <div class="mb-3 text-[13px] font-bold uppercase tracking-[1.2px] text-navy/60">
        Nuestros servicios
      </div>
      <h2 class="m-0 mb-[14px] text-[32px] font-bold leading-[1.12] tracking-[-.8px] sm:text-[40px]">
        Todo lo que tu familia necesita, en un solo lugar
      </h2>
      <p class="m-0 text-[18px] font-normal leading-[1.55] text-[#5a6a7a]">
        Cuatro grandes grupos de beneficios pensados para el día a día de las
        familias de la fuerza pública.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-[22px] sm:grid-cols-2 lg:grid-cols-4">
      {
        GRUPOS.map((g, i) => (
          <div
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
            class="group cursor-default rounded-[18px] border border-[#dbe7ef] bg-white p-7 transition-[transform,box-shadow,border-color] duration-300 ease-out hover:-translate-y-2 hover:scale-[1.03] hover:border-cyan hover:shadow-[0_30px_60px_rgba(1,17,38,.16)]"
          >
            <div class="mb-[18px] flex h-[54px] w-[54px] items-center justify-center rounded-[14px] bg-cyan text-navy transition-[transform,background-color,color] duration-300 ease-out group-hover:scale-110 group-hover:bg-navy group-hover:text-cyan">
              <Icon name={g.icon} size={27} />
            </div>
            <h3 class="m-0 mb-2 text-[19px] font-semibold">{g.title}</h3>
            <p class="m-0 text-[15px] font-normal leading-[1.55] text-[#5a6a7a]">
              {g.desc}
            </p>
          </div>
        ))
      }
    </div>

    <div data-reveal class="mt-11 text-center">
      <a
        href="/servicios"
        class="btn-shine inline-flex items-center gap-2 rounded-full bg-orange px-[30px] py-[15px] text-[16px] font-semibold text-white no-underline shadow-[0_12px_32px_rgba(243,70,22,.42)] transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_48px_rgba(243,70,22,.6)] active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-navy focus-visible:ring-offset-2 focus-visible:ring-offset-ice"
      >
        Ver todos los servicios
        <Icon name="arrowRight" size={18} stroke={2.2} />
      </a>
    </div>
  </div>
</section>

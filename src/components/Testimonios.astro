---
/* === VIDEOS REALES DE TESTIMONIOS (Cloudinary) ===
   Verticales 9:16 (grabados con celular). f_auto/q_auto: Cloudinary sirve el
   formato compatible con cada navegador (los .mov se transcodifican solos).
   poster = fotograma 0 del propio video (so_0,f_jpg). */
const CLOUD = "https://res.cloudinary.com/dzh85ye7y/video/upload";
const VIDEOS = [
  "v1783372764/59fdd258-247d-440d-a1b4-3ae9343be49b_pdf725.mov",
  "v1783372770/ad20d9cc-7491-40ef-a7ea-22fd972d7a18_w5klnm.mp4",
  "v1783372776/eab62dc1-9ba9-4b26-acbc-52268e5ae35f_wkonrr.mp4",
  "v1783372788/1._CREMIL_Alexander_Arvelaez_oqpxxa.mov",
  "v1783372801/1._CREMIL_Fernando_Orozco_umkh69.mp4",
  "v1783372808/1._CREMIL_VID-20241205-WA0083_ocbw04.mp4",
].map((path) => ({
  src: `${CLOUD}/f_auto,q_auto/${path}`,
  poster: `${CLOUD}/so_0,f_jpg,q_auto/${path.replace(/\.(mov|mp4)$/, ".jpg")}`,
}));
/* === FIN VIDEOS === */
---
<section id="testimonios" class="tst-hero relative overflow-hidden">
  {/* === FONDO BEIGE TESTIMONIOS (reversible) === */}
  <div class="tst-mesh" aria-hidden="true">
    <span class="tst-blob tst-blob--a"></span>
    <span class="tst-blob tst-blob--b"></span>
  </div>
  {/* === FIN === */}

  <div class="relative z-10 mx-auto max-w-[1180px] px-6 py-[88px] text-center">
    <div data-reveal>
      <div class="mb-3 text-[16px] font-bold uppercase tracking-[1.6px] text-orange sm:text-[18px]">
        Testimonios
      </div>
      <h2 class="m-0 mb-14 text-[40px] font-bold leading-[1.1] tracking-[-.8px] text-navy sm:text-[52px] lg:text-[60px]">
        La voz de quienes ya nos eligieron
      </h2>
    </div>

    {/* === GRID DE VIDEOS DE TESTIMONIOS (verticales 9:16, 3×2 desktop / 2 tablet / 1 móvil) ===
        <video> nativo: controls (play manual), SIN autoplay (6 a la vez saturarían),
        playsinline (móvil reproduce dentro de la card), preload="metadata" (no baja
        los 6 completos), object-cover (llena la card sin deformar). */}
    <div class="mx-auto grid max-w-[420px] grid-cols-1 gap-6 sm:max-w-[680px] sm:grid-cols-2 lg:max-w-[980px] lg:grid-cols-3">
      {
        VIDEOS.map((v, i) => (
          <div
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
            class="aspect-[9/16] overflow-hidden rounded-2xl border-t-2 border-orange/70 bg-navy shadow-[0_18px_44px_-18px_rgba(1,17,38,.28)]"
          >
            <video
              class="h-full w-full object-cover"
              src={v.src}
              poster={v.poster}
              controls
              playsinline
              preload="metadata"
            >
              Tu navegador no soporta video HTML5.
            </video>
          </div>
        ))
      }
    </div>
    {/* === FIN GRID DE VIDEOS === */}
  </div>
</section>

{/* CTA de cierre — banda navy que conecta con el footer navy */}
<section class="bg-navy text-white" style="background:#011126;">
  <div class="mx-auto max-w-[820px] px-6 pt-[96px] pb-[104px] text-center">
    <h2
      data-reveal
      class="m-0 text-balance text-[32px] font-bold leading-[1.12] tracking-[-.6px] sm:text-[44px] lg:text-[52px]"
    >
      ¿Listo para que tu familia también esté respaldada?
    </h2>
    <p data-reveal class="m-0 mt-5 text-[16px] font-medium text-cyan sm:text-[18px]">
      Únete a las más de 20.000 familias que ya confían en Servimil.
    </p>
    <div data-reveal class="mt-9">
      <a
        href="https://wa.me/573181626167"
        target="_blank"
        rel="noopener"
        class="btn-shine inline-block rounded-full bg-orange px-8 py-4 text-[16px] font-bold text-white shadow-[0_16px_38px_-10px_rgba(243,70,22,.55)] transition-[transform,box-shadow] duration-200 ease-out hover:scale-[1.04] hover:shadow-[0_20px_46px_-8px_rgba(243,70,22,.7)] active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
      >
        Contáctanos por WhatsApp
      </a>
    </div>
  </div>
</section>

{/* === FONDO BEIGE TESTIMONIOS (reversible) === */}
<style>
  .tst-hero {
    /* degradado MUY sutil beige → crema apenas más claro */
    background: linear-gradient(170deg, #F0ECE4 0%, #EAE5DD 55%, #E5DFD5 100%);
  }
  .tst-mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .tst-blob {
    position: absolute;
    border-radius: 9999px;
    filter: blur(130px);
    background: #F34616;
  }
  .tst-blob--a {
    top: -160px;
    left: -120px;
    width: 500px;
    height: 500px;
    opacity: 0.06;
  }
  .tst-blob--b {
    bottom: -180px;
    right: -140px;
    width: 460px;
    height: 460px;
    opacity: 0.07;
  }
</style>
{/* === FIN === */}

---
/* === VIDEOS REALES DE TESTIMONIOS (Cloudinary) ===
   Verticales 9:16 (grabados con celular). f_auto/q_auto: Cloudinary sirve el
   formato compatible con cada navegador (los .mov se transcodifican solos).
   poster = fotograma 0 del propio video (so_0,f_jpg). */
const CLOUD = "https://res.cloudinary.com/dzh85ye7y/video/upload";
const VIDEOS = [
  "v1783372764/59fdd258-247d-440d-a1b4-3ae9343be49b_pdf725.mov",
  "v1783372770/ad20d9cc-7491-40ef-a7ea-22fd972d7a18_w5klnm.mp4",
  "v1783372776/eab62dc1-9ba9-4b26-acbc-52268e5ae35f_wkonrr.mp4",
  "v1783372788/1._CREMIL_Alexander_Arvelaez_oqpxxa.mov",
  "v1783372801/1._CREMIL_Fernando_Orozco_umkh69.mp4",
  "v1783372808/1._CREMIL_VID-20241205-WA0083_ocbw04.mp4",
].map((path) => ({
  src: `${CLOUD}/f_auto,q_auto/${path}`,
  poster: `${CLOUD}/so_0,f_jpg,q_auto/${path.replace(/\.(mov|mp4)$/, ".jpg")}`,
}));
/* === FIN VIDEOS === */
---
<section id="testimonios" class="tst-hero relative overflow-hidden">
  {/* === FONDO BEIGE TESTIMONIOS (reversible) === */}
  <div class="tst-mesh" aria-hidden="true">
    <span class="tst-blob tst-blob--a"></span>
    <span class="tst-blob tst-blob--b"></span>
  </div>
  {/* === FIN === */}

  <div class="relative z-10 mx-auto max-w-[1180px] px-6 py-[88px] text-center">
    <div data-reveal>
      <div class="mb-3 text-[16px] font-bold uppercase tracking-[1.6px] text-orange sm:text-[18px]">
        Testimonios
      </div>
      <h2 class="m-0 mb-14 text-[40px] font-bold leading-[1.1] tracking-[-.8px] text-navy sm:text-[52px] lg:text-[60px]">
        La voz de quienes ya nos eligieron
      </h2>
    </div>

    {/* === CARRUSEL DE VIDEOS DE TESTIMONIOS (2026-07-16, reversible) ===
        Antes: grid 3×2 con los 6 videos a la vez (revertir con git si hace
        falta: commit 59b42b8 y anteriores). Ahora: UN video vertical 9:16 a
        la vez (~560px alto desktop), flechas ‹ › a los lados (navegación
        CIRCULAR), dots clickeables debajo (activo naranja). Al cambiar de
        slide se PAUSAN todos los videos (solo se reproduce el visible).
        <video> nativo: controls, SIN autoplay, playsinline, preload=metadata. */}
    <div class="tst-carousel mx-auto max-w-[520px]" data-tst-carousel data-reveal>
      <div class="flex items-center justify-center gap-3 sm:gap-5">
        <button
          type="button"
          data-tst-prev
          aria-label="Testimonio anterior"
          class="tst-arrow flex h-11 w-11 flex-none cursor-pointer items-center justify-center rounded-full border border-navy/15 bg-white text-navy shadow-[0_8px_22px_-8px_rgba(1,17,38,.35)] transition-[background-color,color,transform] duration-200 hover:bg-orange hover:text-white active:scale-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 sm:h-12 sm:w-12"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        </button>

        {/* Viewport: un slide visible; el track se desliza con translateX */}
        <div class="w-full max-w-[315px] overflow-hidden rounded-2xl">
          <div data-tst-track class="tst-track flex">
            {
              VIDEOS.map((v, i) => (
                <div class="w-full flex-none" data-tst-slide>
                  <div class="aspect-[9/16] max-h-[560px] overflow-hidden rounded-2xl border-t-2 border-orange/70 bg-navy shadow-[0_18px_44px_-18px_rgba(1,17,38,.28)]">
                    <video
                      class="h-full w-full object-cover"
                      src={v.src}
                      poster={v.poster}
                      controls
                      playsinline
                      preload="metadata"
                      aria-label={`Testimonio en video ${i + 1} de ${VIDEOS.length}`}
                    >
                      Tu navegador no soporta video HTML5.
                    </video>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <button
          type="button"
          data-tst-next
          aria-label="Testimonio siguiente"
          class="tst-arrow flex h-11 w-11 flex-none cursor-pointer items-center justify-center rounded-full border border-navy/15 bg-white text-navy shadow-[0_8px_22px_-8px_rgba(1,17,38,.35)] transition-[background-color,color,transform] duration-200 hover:bg-orange hover:text-white active:scale-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 sm:h-12 sm:w-12"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>

      {/* Dots indicadores (clickeables) */}
      <div class="mt-6 flex items-center justify-center gap-2.5" role="tablist" aria-label="Elegir testimonio">
        {
          VIDEOS.map((_, i) => (
            <button
              type="button"
              data-tst-dot={i}
              role="tab"
              aria-label={`Ir al testimonio ${i + 1}`}
              class="tst-dot h-2.5 w-2.5 cursor-pointer rounded-full border-0 bg-navy/25 p-0 transition-[background-color,transform] duration-200 hover:bg-navy/45 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2"
            />
          ))
        }
      </div>
    </div>
    {/* === FIN CARRUSEL DE VIDEOS === */}
  </div>
</section>

{/* CTA de cierre — banda navy que conecta con el footer navy */}
<section class="bg-navy text-white" style="background:#011126;">
  <div class="mx-auto max-w-[820px] px-6 pt-[96px] pb-[104px] text-center">
    <h2
      data-reveal
      class="m-0 text-balance text-[32px] font-bold leading-[1.12] tracking-[-.6px] sm:text-[44px] lg:text-[52px]"
    >
      ¿Listo para que tu familia también esté respaldada?
    </h2>
    <p data-reveal class="m-0 mt-5 text-[16px] font-medium text-cyan sm:text-[18px]">
      Únete a las más de 20.000 familias que ya confían en Servimil.
    </p>
    <div data-reveal class="mt-9">
      <a
        href="https://wa.me/573181626167"
        target="_blank"
        rel="noopener"
        class="btn-shine inline-block rounded-full bg-orange px-8 py-4 text-[16px] font-bold text-white shadow-[0_16px_38px_-10px_rgba(243,70,22,.55)] transition-[transform,box-shadow] duration-200 ease-out hover:scale-[1.04] hover:shadow-[0_20px_46px_-8px_rgba(243,70,22,.7)] active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
      >
        Contáctanos por WhatsApp
      </a>
    </div>
  </div>
</section>

{/* === CARRUSEL TESTIMONIOS: estilos + lógica (2026-07-16, reversible) === */}
<style>
  .tst-track {
    transition: transform 0.45s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .tst-dot.is-active {
    background: #F34616;
    transform: scale(1.25);
  }
  @media (prefers-reduced-motion: reduce) {
    .tst-track,
    .tst-dot,
    .tst-arrow {
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-tst-carousel]");
    if (!root) return;
    const track = root.querySelector("[data-tst-track]");
    const slides = root.querySelectorAll("[data-tst-slide]");
    const dots = root.querySelectorAll("[data-tst-dot]");
    const n = slides.length;
    let idx = 0;

    function go(next) {
      // circular: del último salta al primero y viceversa
      idx = (next + n) % n;
      track.style.transform = `translateX(-${idx * 100}%)`;
      dots.forEach((d, i) => {
        d.classList.toggle("is-active", i === idx);
        d.setAttribute("aria-selected", String(i === idx));
      });
      // pausa todos los videos que no están visibles
      slides.forEach((s, i) => {
        const v = s.querySelector("video");
        if (v && i !== idx && !v.paused) v.pause();
      });
    }

    root.querySelector("[data-tst-prev]")?.addEventListener("click", () => go(idx - 1));
    root.querySelector("[data-tst-next]")?.addEventListener("click", () => go(idx + 1));
    dots.forEach((d, i) => d.addEventListener("click", () => go(i)));
    go(0);
  })();
</script>
{/* === FIN CARRUSEL === */}

{/* === FONDO BEIGE TESTIMONIOS (reversible) === */}
<style>
  .tst-hero {
    /* degradado MUY sutil beige → crema apenas más claro */
    background: linear-gradient(170deg, #F0ECE4 0%, #EAE5DD 55%, #E5DFD5 100%);
  }
  .tst-mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .tst-blob {
    position: absolute;
    border-radius: 9999px;
    filter: blur(130px);
    background: #F34616;
  }
  .tst-blob--a {
    top: -160px;
    left: -120px;
    width: 500px;
    height: 500px;
    opacity: 0.06;
  }
  .tst-blob--b {
    bottom: -180px;
    right: -140px;
    width: 460px;
    height: 460px;
    opacity: 0.07;
  }
</style>
{/* === FIN === */}

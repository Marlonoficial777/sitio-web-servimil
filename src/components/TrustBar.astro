---
import Icon from "./Icon.astro";

const ITEMS = [
  { icon: "clock", title: "Disponibilidad 24/7/365", desc: "Siempre que nos necesites, estamos." },
  { icon: "eye", title: "Transparencia total", desc: "Cero descuentos no deseados." },
  { icon: "users", title: "Confianza", desc: "Un equipo comprometido contigo." },
];
---
<section class="border-b border-[#dbe7ef] bg-white">
  <div
    class="mx-auto grid max-w-[1200px] grid-cols-1 gap-5 px-6 py-11 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      ITEMS.map((it, i) => (
        <div data-reveal style={`--reveal-delay:${i * 90}ms`} class="flex items-center gap-4">
          <div class="flex h-[52px] w-[52px] flex-none items-center justify-center rounded-[13px] bg-cyan text-navy">
            <Icon name={it.icon} size={26} stroke={1.9} />
          </div>
          <div>
            <div class="text-[16px] font-semibold">{it.title}</div>
            <div class="text-[14px] text-[#6b7a88]">{it.desc}</div>
          </div>
        </div>
      ))
    }
  </div>
</section>

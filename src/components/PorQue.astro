---
import Icon from "./Icon.astro";

// Foto: militar abrazando a su familia en casa.
const FOTO =
  "https://res.cloudinary.com/dzh85ye7y/image/upload/q_auto/f_auto/v1782488068/hf_20260626_145552_ad840606-5567-49c0-9c0a-ac840fa62b3b_qkpl28.png";

const RAZONES = [
  { icon: "ban", title: "Adiós a los descuentos fantasma", desc: "¿Te descuentan de la nómina y ni sabes por qué? Te ayudamos a eliminar esos descuentos garrapata que no te dan nada a cambio." },
  { icon: "money", title: "Te sacamos del hueco", desc: "Esos créditos que te tienen ahogado tienen solución. Te ayudamos a respirar y a recuperar el control de tu plata." },
  { icon: "shield", title: "Nosotros sí damos la cara", desc: "No somos un descuento invisible más. Estamos 24/7 de manera digital, los 365 días del año, y nuestras oficinas son reales: también te atendemos de forma presencial." },
  { icon: "users", title: "Para toda tu familia", desc: "Beneficios que también disfrutan los tuyos: entretenimiento y pantallas de streaming para que toda la familia esté incluida." },
];

---
<section
  class="relative overflow-hidden bg-navy"
  style="background:linear-gradient(180deg,#06223a 0%,#04223a 40%,#011126 100%);"
>
  <div
    class="pointer-events-none absolute inset-0"
    style="background:radial-gradient(700px 400px at 50% 0%,rgba(150,221,237,.16),transparent 65%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6 pt-[88px] text-center">
    <h2 data-reveal class="pq-led m-0 font-bold tracking-[-.5px] text-white" style="font-size:clamp(34px,5vw,56px);">
      ¿Por qué Servimil?
    </h2>
  </div>

  <div class="relative z-10 mx-auto grid max-w-[1200px] items-center gap-10 px-6 pb-[88px] pt-12 lg:grid-cols-2 lg:gap-16">
    {/* ---------- IZQUIERDA: escudo 3D (móvil: arriba) ---------- */}
    <div data-reveal class="order-1 flex justify-center">
      <div class="pq-float relative flex items-center justify-center">
        {/* glow cian difuso detrás */}
        <div
          class="pointer-events-none absolute left-1/2 top-1/2 h-[78%] w-[78%] -translate-x-1/2 -translate-y-1/2 rounded-full"
          style="background:radial-gradient(circle,rgba(150,221,237,.4),rgba(150,221,237,0) 68%);filter:blur(34px);"
          aria-hidden="true"
        ></div>
        <img
          src={FOTO}
          alt="Militar abrazando a su familia en casa"
          loading="lazy"
          decoding="async"
          class="relative aspect-[4/5] w-full max-w-[440px] rounded-3xl object-cover shadow-[0_28px_70px_-20px_rgba(0,0,0,.6)] ring-1 ring-white/10"
        />
      </div>
    </div>

    {/* ---------- DERECHA: título + 4 razones en lista ---------- */}
    <div class="order-2">
      <h2 data-reveal class="m-0 mb-9 text-[30px] font-bold leading-[1.14] tracking-[-.8px] text-white sm:text-[38px]">
        No somos una empresa más. Somos los que sí responden.
      </h2>

      <ul class="flex flex-col">
        {
          RAZONES.map((r, i) => (
            <li
              data-reveal
              style={`--reveal-delay:${140 + i * 90}ms`}
              class="group flex items-start gap-4 rounded-2xl border-b border-white/10 px-3 py-5 transition-colors duration-200 last:border-b-0 hover:bg-white/10"
            >
              <span class="flex h-11 w-11 flex-none items-center justify-center rounded-xl bg-cyan text-navy transition-transform duration-300 ease-out group-hover:scale-110">
                <Icon name={r.icon} size={22} stroke={1.9} />
              </span>
              <div class="min-w-0">
                <h3 class="m-0 mb-1 text-[17px] font-semibold text-white">{r.title}</h3>
                <p class="m-0 text-[14px] leading-[1.55] text-white/70">{r.desc}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .pq-float {
    animation: pqFloat 4s ease-in-out infinite;
  }
  @keyframes pqFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pq-float {
      animation: none;
    }
  }
</style>

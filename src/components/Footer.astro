---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { WHATSAPP_URL, WHATSAPP_DISPLAY } from "../lib/site";
---
<footer class="bg-navy text-[#92a3b5]">
  <div
    class="mx-auto flex max-w-[1200px] flex-wrap items-start justify-between gap-8 px-6 pb-10 pt-14"
  >
    <div class="max-w-[300px]">
      <div class="mb-[14px]">
        <Logo dark />
      </div>
      <p class="m-0 text-[14px] font-normal leading-[1.6]">
        Beneficios y servicios para los integrantes del Ministerio de Defensa y
        la fuerza pública.
      </p>
    </div>

    <div class="flex flex-col gap-3">
      <div class="mb-0.5 text-[15px] font-semibold text-white">Contacto</div>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 rounded-sm text-[14px] text-[#92a3b5] no-underline transition-colors hover:text-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
      >
        <Icon name="whatsapp" size={16} stroke={2} class="text-cyan" />
        {WHATSAPP_DISPLAY}
      </a>
      <a
        href="https://www.google.com/maps/dir/?api=1&destination=Cra%207C%20%23%20125-36%2C%20Bogot%C3%A1%2C%20Colombia"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Abrir en Google Maps y ver cómo llegar a Cra 7C # 125-36, Bogotá"
        class="flex items-center gap-2 rounded-sm text-[14px] text-[#92a3b5] no-underline transition-colors hover:text-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-none text-cyan">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Cra 7C # 125-36, Bogotá, Colombia
      </a>
    </div>

    <div class="flex flex-col gap-3">
      <div class="mb-0.5 text-[15px] font-semibold text-white">Síguenos</div>
      <div class="flex gap-3">
        <a
          href="https://www.facebook.com/share/1UFsiqQa7w/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-cyan/10 text-cyan transition-colors hover:bg-cyan hover:text-navy active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/servimil.col"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-cyan/10 text-cyan transition-colors hover:bg-cyan hover:text-navy active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <path d="M17.5 6.5h.01"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-cyan/[.12]">
    <div class="mx-auto max-w-[1200px] px-6 py-5 text-[13px] text-[#647689]">
      © 2026 Servimil. Todos los derechos reservados.
    </div>
  </div>
</footer>

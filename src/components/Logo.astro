---
/** Logo oficial SERVIMIL (imagen). dark=true → se renderiza en blanco. */
interface Props {
  dark?: boolean; // true = sobre fondo oscuro (header overlay / scroll, footer)
}
const { dark = false } = Astro.props;
const LOGO =
  "https://res.cloudinary.com/dzh85ye7y/image/upload/q_auto/f_auto/v1781730267/Logo-Horizontal-Original-2_ys22y9.png";
---
<a
  href="#top"
  aria-label="Servimil — inicio"
  class="inline-flex items-center no-underline transition-transform duration-300 hover:-translate-y-0.5 hover:scale-[1.03]"
>
  <img
    src={LOGO}
    alt="Servimil"
    class="h-16 w-auto md:h-20"
    style={dark ? "filter:brightness(0) invert(1);" : ""}
    loading="eager"
    decoding="async"
  />
</a>

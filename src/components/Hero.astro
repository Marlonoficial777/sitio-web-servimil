---
import Icon from "./Icon.astro";
import { WHATSAPP_URL } from "../lib/site";

const VIDEO_URL =
  "https://res.cloudinary.com/dzh85ye7y/video/upload/v1781727489/hf_20260617_200631_87bd6292-1278-4edf-b339-65579f26455e_zd1gav.mp4";
// Poster = fotograma 0 del propio video (Cloudinary genera el JPG)
const POSTER_URL =
  "https://res.cloudinary.com/dzh85ye7y/video/upload/so_0,q_auto,f_jpg/v1781727489/hf_20260617_200631_87bd6292-1278-4edf-b339-65579f26455e_zd1gav.jpg";
---
<section
  id="top"
  class="relative isolate flex min-h-[100svh] items-center overflow-hidden bg-navy text-white"
>
  <!-- ============ VIDEO DE FONDO ============ -->
  <video
    id="heroVideo"
    poster={POSTER_URL}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
    tabindex="-1"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    style="background:#011126;"
  >
    <source data-src={VIDEO_URL} type="video/mp4" />
  </video>

  <!-- ============ OVERLAY OSCURO ============ -->
  <div
    class="absolute inset-0 -z-10"
    style="background:radial-gradient(1100px 520px at 78% -10%,rgba(150,221,237,.18),transparent 60%),rgba(1,17,38,.58);"
  ></div>

  <!-- ============ CONTENIDO ============ -->
  <div
    class="relative z-10 mx-auto w-full max-w-[1200px] px-6 py-20 md:py-[88px]"
  >
    <div data-reveal>
      <h1
        class="m-0 mb-5 text-[40px] font-bold leading-[1.07] tracking-[-1.2px] text-balance sm:text-[54px]"
      >
        Servimil te respalda<br />a ti y a tu familia
      </h1>
      <p
        class="m-0 mb-[34px] max-w-[520px] text-[18px] font-normal leading-[1.55] text-[#cfdae6] sm:text-[20px]"
      >
        Más beneficios, más tranquilidad, más bienestar para quienes más amas.
      </p>
      <div class="flex flex-wrap gap-[14px]">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-[9px] rounded-full border-[1.5px] border-cyan/40 bg-white/[.06] px-[26px] py-[15px] text-[16px] font-medium text-white no-underline backdrop-blur-sm transition-colors hover:border-cyan hover:bg-cyan/10 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
        >
          <Icon name="whatsapp" size={19} stroke={2} />
          Contáctanos por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const v = document.getElementById("heroVideo");
    if (!v) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return; // solo poster, no reproducir
    const s = v.querySelector("source");
    if (s && s.dataset.src) {
      s.src = s.dataset.src;
      v.load();
      v.play().catch(() => {});
    }
  })();
</script>

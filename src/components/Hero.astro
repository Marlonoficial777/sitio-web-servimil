---
import Icon from "./Icon.astro";
import { WHATSAPP_URL, REGISTER_HREF } from "../lib/site";

const VIDEO_URL =
  "https://res.cloudinary.com/dzh85ye7y/video/upload/q_auto/f_auto/v1781727489/hf_20260617_200631_87bd6292-1278-4edf-b339-65579f26455e_zd1gav.mp4";
// Poster = fotograma 0 del propio video (Cloudinary genera el JPG)
const POSTER_URL =
  "https://res.cloudinary.com/dzh85ye7y/video/upload/so_0,q_auto,f_jpg/v1781727489/hf_20260617_200631_87bd6292-1278-4edf-b339-65579f26455e_zd1gav.jpg";
---
<section
  id="top"
  class="relative isolate overflow-hidden bg-navy text-white"
>
  <!-- ============ VIDEO DE FONDO ============ -->
  <video
    id="heroVideo"
    poster={POSTER_URL}
    muted
    loop
    playsinline
    preload="none"
    aria-hidden="true"
    tabindex="-1"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    style="background:#011126;"
  >
    <source data-src={VIDEO_URL} type="video/mp4" />
  </video>

  <!-- ============ OVERLAY OSCURO ============ -->
  <div
    class="absolute inset-0 -z-10"
    style="background:radial-gradient(1100px 520px at 78% -10%,rgba(150,221,237,.18),transparent 60%),rgba(1,17,38,.58);"
  ></div>

  <!-- ============ CONTENIDO ============ -->
  <div
    class="relative z-10 mx-auto grid max-w-[1200px] grid-cols-1 items-center gap-12 px-6 py-20 md:grid-cols-[1.08fr_.92fr] md:py-[88px]"
  >
    <div data-reveal>
      <div
        class="mb-[22px] inline-flex items-center gap-2 rounded-full border border-cyan/40 bg-cyan/[.14] px-[14px] py-[7px] text-[13px] font-semibold tracking-[.4px] text-cyan"
      >
        <span class="h-[7px] w-[7px] rounded-full bg-cyan"></span>
        PARA LAS FUERZAS ARMADAS Y SUS FAMILIAS
      </div>
      <h1
        class="m-0 mb-5 text-[40px] font-bold leading-[1.07] tracking-[-1.2px] text-balance sm:text-[54px]"
      >
        Servimil te respalda a ti y a tu familia
      </h1>
      <p
        class="m-0 mb-[34px] max-w-[520px] text-[18px] font-normal leading-[1.55] text-[#cfdae6] sm:text-[20px]"
      >
        Más beneficios, más tranquilidad, más bienestar para quienes más amas.
      </p>
      <div class="flex flex-wrap gap-[14px]">
        <a
          href={REGISTER_HREF}
          class="inline-flex items-center gap-[9px] rounded-full bg-orange px-7 py-[15px] text-[16px] font-semibold text-white no-underline shadow-[0_12px_32px_rgba(243,70,22,.42)] transition-transform hover:-translate-y-0.5"
        >
          Regístrate
        </a>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-[9px] rounded-full border-[1.5px] border-cyan/40 bg-white/[.06] px-[26px] py-[15px] text-[16px] font-medium text-white no-underline backdrop-blur-sm transition-colors hover:border-cyan hover:bg-cyan/10"
        >
          <Icon name="whatsapp" size={19} stroke={2} />
          Contáctanos por WhatsApp
        </a>
      </div>
    </div>

    <!-- Columna derecha: solo el badge flotante sobre el video -->
    <div data-reveal class="relative hidden min-h-[280px] md:block">
      <div
        class="absolute bottom-0 left-0 flex items-center gap-[13px] rounded-2xl bg-white px-5 py-4 text-navy shadow-[0_18px_44px_rgba(0,0,0,.45)]"
      >
        <div class="flex h-[42px] w-[42px] items-center justify-center rounded-[11px] bg-cyan text-navy">
          <Icon name="check" size={22} stroke={2.2} />
        </div>
        <div>
          <div class="text-[16px] font-bold">+5.000 familias</div>
          <div class="text-[13px] text-[#6b7a88]">respaldadas por Servimil</div>
        </div>
      </div>
    </div>

    <!-- Badge en móvil (bajo los CTA) -->
    <div data-reveal class="md:hidden">
      <div
        class="inline-flex items-center gap-[13px] rounded-2xl bg-white px-5 py-4 text-navy shadow-[0_18px_44px_rgba(0,0,0,.45)]"
      >
        <div class="flex h-[42px] w-[42px] items-center justify-center rounded-[11px] bg-cyan text-navy">
          <Icon name="check" size={22} stroke={2.2} />
        </div>
        <div>
          <div class="text-[16px] font-bold">+5.000 familias</div>
          <div class="text-[13px] text-[#6b7a88]">respaldadas por Servimil</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const v = document.getElementById("heroVideo");
    if (!v) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return; // solo poster, no reproducir
    const s = v.querySelector("source");
    if (s && s.dataset.src) {
      s.src = s.dataset.src;
      v.load();
      v.play().catch(() => {});
    }
  })();
</script>

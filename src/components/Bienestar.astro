---
import Icon from "./Icon.astro";
import { BIENESTAR } from "../lib/site";
---
<section id="conocenos" class="bg-navy text-white">
  <div class="mx-auto max-w-[1200px] px-6 py-[88px]">
    <div data-reveal class="mb-11 max-w-[680px]">
      <div class="mb-3 text-[13px] font-bold uppercase tracking-[1.2px] text-cyan">
        Bienestar y salud
      </div>
      <h2 class="m-0 mb-[14px] text-[32px] font-bold leading-[1.12] tracking-[-.8px] sm:text-[40px]">
        Te cuidamos en casa y en cada paso
      </h2>
      <p class="m-0 text-[18px] font-normal leading-[1.55] text-[#b8c6d4]">
        Salud y acompañamiento al alcance de tu familia, cuando y donde lo
        necesiten.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
      {
        BIENESTAR.map((b, i) => (
          <article
            data-reveal
            style={`--reveal-delay:${i * 80}ms`}
            class="group flex items-start gap-4 rounded-2xl border border-cyan/[.14] bg-white/5 p-[22px] transition-[transform,background,border-color] duration-300 ease-out hover:-translate-y-1 hover:border-cyan/50 hover:bg-cyan/[.12]"
          >
            <div class="flex h-[46px] w-[46px] flex-none items-center justify-center rounded-xl bg-cyan/[.16] text-cyan transition-transform duration-300 ease-out group-hover:scale-110">
              <Icon name={b.icon} size={24} />
            </div>
            <div>
              <h3 class="m-0 mb-[5px] text-[17px] font-semibold">{b.title}</h3>
              <p class="m-0 text-[14px] font-normal leading-[1.5] text-[#a6b6c5]">
                {b.desc}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

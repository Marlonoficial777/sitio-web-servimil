---
import Icon from "./Icon.astro";
import { WHATSAPP_URL } from "../lib/site";
---
<section
  id="registro"
  class="bg-navy text-white"
  style="background:radial-gradient(900px 420px at 50% 0%,rgba(150,221,237,.2),transparent 60%),#011126;"
>
  <div class="mx-auto max-w-[860px] px-6 py-[88px] text-center">
    <div data-reveal>
      <h2 class="m-0 mb-4 text-[34px] font-bold leading-[1.1] tracking-[-1px] text-balance sm:text-[44px]">
        ¡Afíliate hoy y disfruta todos estos beneficios!
      </h2>
      <p class="m-0 mb-9 text-[18px] font-normal text-[#b8c6d4] sm:text-[19px]">
        Tu familia merece el respaldo de Servimil. Empieza en minutos.
      </p>
      <div class="flex flex-wrap justify-center gap-[14px]">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-[9px] rounded-full border-[1.5px] border-cyan/40 bg-transparent px-7 py-[15px] text-[16px] font-medium text-white no-underline transition-colors hover:border-cyan hover:bg-cyan/10 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
        >
          <Icon name="whatsapp" size={19} stroke={2} />
          WhatsApp
        </a>
        <button
          type="button"
          data-open-credito
          class="btn-shine inline-flex cursor-pointer items-center gap-[9px] rounded-full border-none bg-orange px-7 py-[15px] text-[16px] font-semibold text-white shadow-[0_12px_32px_rgba(243,70,22,.42)] transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_48px_rgba(243,70,22,.6)] active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-navy"
        >
          Solicita tu crédito
        </button>
      </div>
    </div>
  </div>
</section>
